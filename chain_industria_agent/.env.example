# Chain Industria Agent — copia a .env:  python scripts/setup_env.py

ORG_NAME=Chain Industria

# --- LLM (Anthropic) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Búsqueda web (Tavily) ---
# https://app.tavily.com/
TAVILY_API_KEY=
SEARCH_PROVIDER=auto

# --- Notion ---
# https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_VERSION=2022-06-28
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=

# --- GitHub ---
# https://github.com/settings/tokens  (scope: repo)
GITHUB_TOKEN=
GITHUB_REPO=chainindustria/chain_industria_agent
GITHUB_API_URL=https://api.github.com

# --- AgentMemory HTTP (opcional) ---
AGENTMEMORY_URL=
AGENTMEMORY_API_KEY=
